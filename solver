"""
Topological Fractional AI - Core Engine
Module: solver.py

Description:
Main orchestration class. Transforms a raw 1D time-series into a 28-parameter 
Topological Signature vector, without using gradient descent or neural networks.

Pipeline:
1. (Optional) Estimate local fractional order (Memory proxy via Hurst Exponent).
2. Orthogonal Spectral Decomposition (Topology).
3. Causal Coupling Matrix (Mij) Extraction.
4. Symmetry Compression into exactly 28 independent parameters.

Author: Patrice Portemann
"""

import numpy as np
import warnings

# Import core modules (Works both as standalone and as a package)
try:
    from .topology import TopologicalPrior, CausalSolver
except ImportError:
    from topology import TopologicalPrior, CausalSolver

class NoeticEngine:
    """
    The main interface for the Topological Fractional AI engine.
    Acts as a drop-in replacement for standard feature extraction in ML pipelines.
    """
    
    def __init__(self, n_plans: int = 7, spectral_bands: dict = None):
        """
        Initializes the engine.
        Args:
            n_plans (int): Number of orthogonal spectral planes (Default 7).
            spectral_bands (dict): Custom frequency bands. If None, uses standard Noetic bands.
        """
        self.n_plans = n_plans
        self.topology = TopologicalPrior(n_plans=n_plans, spectral_bands=spectral_bands)
        self.causal_solver = CausalSolver()

    @staticmethod
    def _estimate_fractional_order(signal: np.ndarray) -> float:
        """
        Proxy for the Atangana-Baleanu fractional order (alpha) using the Hurst Exponent.
        H=0.5 -> Standard Markovian (No memory)
        H>0.5 -> Fractional Non-Markovian (Heavy tail memory)
        """
        lags = range(2, min(len(signal)//2, 100))
        tau = [np.std(np.subtract(signal[lag:], signal[:-lag])) for lag in lags]
        poly = np.polyfit(np.log(lags), np.log(tau), 1)
        H = poly[0]
        # Map Hurst H [0,1] to fractional alpha [0,1]
        return np.clip(2 * H - 1, 0.01, 0.99)

    def extract_signature(self, raw_signal: np.ndarray, fs: float, 
                          window_sec: float = 2.0, overlap: float = 0.5) -> dict:
        """
        Transforms a raw signal into its Topological Signature.
        
        Args:
            raw_signal (np.ndarray): 1D array of raw time-series data.
            fs (float): Sampling frequency in Hz.
            window_sec (float): Sliding window duration in seconds.
            overlap (float): Fraction of overlap between windows (0.0 to 1.0).
            
        Returns:
            dict: Contains the 28-parameter vector, the fractional order, 
                  and the full Mij matrix for the last window.
        """
        window_size = int(fs * window_sec)
        step = int(window_size * (1 - overlap))
        n_samples = len(raw_signal)
        
        signatures_28 = []
        alphas = []
        last_mij = None

        for start in range(0, n_samples - window_size, step):
            window = raw_signal[start : start + window_size]
            
            # 1. Estimate Memory (Fractional Order)
            alpha = self._estimate_fractional_order(window)
            alphas.append(alpha)
            
            # 2. Topological Decomposition
            psi_space = self.topology.decompose(window, fs)
            
            # 3. Solve for Causal Matrix
            dt = 1.0 / fs
            mij = self.causal_solver.solve_mij(psi_space, dt)
            last_mij = mij
            
            # 4. Compress to 28 independent parameters (Upper triangle)
            features_28 = self.causal_solver.compress_to_28_features(mij)
            signatures_28.append(features_28)
            
        if not signatures_28:
            raise ValueError("Signal too short for the given window size.")

        # Average the topology over time to get a robust signature
        mean_signature_28 = np.mean(signatures_28, axis=0)
        mean_alpha = np.mean(alphas)

        return {
            "topology_28": mean_signature_28,
            "fractional_order": mean_alpha,
            "last_mij_matrix": last_mij
        }


